{
  "name": "recap",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "scripts:add-guest-attendance": "node ./scripts/add-guest-attendance.mjs",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "eas:login": "eas login",
    "eas:credentials:android": "eas credentials -p android",
    "eas:credentials:ios": "eas credentials -p ios",
    "eas:env:development": "eas env:pull --environment development",
    "eas:env:production": "eas env:pull --environment production",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:ios:local": "eas build --profile development --platform ios --local",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:dev:android:local": "eas build --profile development --platform android --local",
    "eas:build:prod:ios": "eas build --profile production --platform ios",
    "eas:build:prod:android": "eas build --profile production --platform android",
    "eas:build:prod:ios:submit": "eas build --profile production --platform ios --auto-submit",
    "eas:build:prod:android:submit": "eas build --profile production --platform android --auto-submit",
    "eas:submit:ios": "eas submit --platform ios --profile production --latest",
    "eas:submit:android": "eas submit --platform android --profile production --latest"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~54.0.33",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "^55.0.4",
    "expo-image": "~3.0.11",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "^55.0.13",
    "expo-notifications": "~0.32.17",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-store-review": "~9.0.9",
    "i18next": "^26.0.6",
    "mixpanel-react-native": "^3.3.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.4",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@trivago/prettier-plugin-sort-imports": "^6.0.2",
    "@types/react": "~19.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "prettier": "^3.6.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
