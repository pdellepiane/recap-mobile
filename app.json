{
  "expo": {
    "name": "recap",
    "slug": "recap",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "recap",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": ["android.permission.RECORD_AUDIO", "android.permission.CAMERA"]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/Splash.png",
          "resizeMode": "cover",
          "imageWidth": 430,
          "backgroundColor": "#222222",
          "dark": {
            "backgroundColor": "#222222"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Recap puede acceder a tus fotos para guardar o compartir imágenes del evento.",
          "cameraPermission": "Recap usa la cámara para que tomes fotos durante el evento."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Recap usa la cámara para que tomes fotos durante el evento.",
          "recordAudioAndroid": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8b3f9070-49ca-488c-9f86-c41c5159a193"
      }
    },
    "owner": "sin-envolturas"
  }
}
